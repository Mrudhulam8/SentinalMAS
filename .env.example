# Groq LLM (free tier at console.groq.com) — used for plain-English finding
# explanations only. Detection itself is keyless; this is purely narrative.
GROQ_API_KEY=

# Threat intelligence
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=

# NVD (CVE lookup) - optional key raises rate limits
NVD_API_KEY=

# Database (persistence is optional; leave blank to run stateless).
# Postgres connection string, e.g. from Supabase → Settings → Database.
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres
DATABASE_URL=

# App — comma-separated allowed frontend origins.
# Add your deployed frontend URL in production, e.g.
# CORS_ORIGINS=http://localhost:5173,https://secureorch.vercel.app
CORS_ORIGINS=http://localhost:5173
