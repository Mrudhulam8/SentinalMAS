# Gemini LLM
GEMINI_API_KEY=

# Threat intelligence
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=

# NVD (CVE lookup) - optional key raises rate limits
NVD_API_KEY=

# Firebase (persistence is optional; leave blank to run stateless)
# Local dev: point to a downloaded service-account file.
FIREBASE_SERVICE_ACCOUNT_PATH=./backend/firebase-service-account.json
# Cloud deploy: paste the service-account JSON as a single-line secret instead
# of committing a file. Takes precedence over the path above when set.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=

# App — comma-separated allowed frontend origins.
# Add your deployed frontend URL in production, e.g.
# CORS_ORIGINS=http://localhost:5173,https://secureorch.vercel.app
CORS_ORIGINS=http://localhost:5173
